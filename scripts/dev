#!/usr/bin/env sh
set -eu

usage() {
  printf '%s\n' \
    'Usage: ./scripts/dev <command>' \
    '' \
    'Commands:' \
    '  up         Build and start the full local stack' \
    '  test       Run backend tests in Docker' \
    '  typecheck  Run mobile TypeScript checks in Docker' \
    '  generate-openapi  Generate mobile API client/types from backend OpenAPI' \
    '  seed-db    Seed database tables in Docker' \
    '  update     Rebuild images and refresh npm install inside Docker volumes' \
    '  config     Render Docker Compose config' \
    '  help       Show this help text'
}

require_mobile_api_base_url() {
  if [ -f .env ]; then
    set -a
    . ./.env
    set +a
  fi

  case "${EXPO_PUBLIC_API_BASE_URL:-}" in
    ""|http://localhost:*|http://127.0.0.1:*)
      printf '%s\n' \
        'EXPO_PUBLIC_API_BASE_URL is required before ./scripts/dev up.' \
        'Set it in .env to your dev machine LAN URL, for example:' \
        'EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8000'
      exit 2
      ;;
  esac
}

case "${1:-help}" in
  up)
    require_mobile_api_base_url
    docker compose up --build
    ;;
  test)
    docker compose build backend-tests
    docker compose run --rm backend-tests
    ;;
  typecheck)
    docker compose build mobile-typecheck
    docker compose run --rm mobile-typecheck
    ;;
  seed-db)
    docker compose build seed-db
    docker compose run --rm seed-db
    ;;
  generate-openapi)
    docker compose build openapi-export
    docker compose run --rm openapi-export
    docker compose build mobile-openapi
    docker compose run --rm mobile-openapi
    ;;
  update)
    docker compose build --pull
    docker compose run --rm mobile npm install
    ;;
  config)
    docker compose --profile tools config
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
