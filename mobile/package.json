{
  "name": "trendwise-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "generate:api": "openapi --input ./src/api/generated/openapi.json --output ./src/api/generated --client fetch --useOptions --useUnionTypes"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "^56.0.8",
    "expo-status-bar": "^56.0.4",
    "react": "19.2.3",
    "react-native": "^0.85.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "openapi-typescript-codegen": "^0.29.0",
    "typescript": "^6.0.3"
  }
}
